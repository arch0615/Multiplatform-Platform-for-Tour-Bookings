{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=BajaTours;User Id=sa;Password=__SET_IN_USER_SECRETS__;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Issuer": "baja-tours-api",
    "Audience": "baja-tours-frontend",
    "SigningKey": "__SET_IN_USER_SECRETS__",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Storage": {
    "Provider": "LocalDisk",
    "LocalPath": "wwwroot/uploads",
    "PublicUrlPath": "/uploads",
    "AllowedImageContentTypes": "image/jpeg,image/png,image/webp",
    "MaxImageBytes": 5242880
  },
  "Payments": {
    "Mode": "Mock",
    "FrontendBaseUrl": "http://localhost:5173",
    "ApiPublicBaseUrl": "http://localhost:5080",
    "MercadoPago": {
      "AccessToken": "",
      "PublicKey": "",
      "WebhookSecret": "",
      "ApiBaseUrl": "https://api.mercadopago.com"
    },
    "PayPal": {
      "ClientId": "",
      "ClientSecret": "",
      "Mode": "sandbox"
    }
  },
  "Notifications": {
    "Email": {
      "Provider": "Noop",
      "FromAddress": "no-reply@bajatours.mx",
      "FromName": "Baja Tours",
      "Smtp": {
        "Host": "",
        "Port": 587,
        "Username": "",
        "Password": "",
        "UseStartTls": true
      }
    },
    "WhatsApp": {
      "Provider": "twilio",
      "AccountSid": "",
      "AuthToken": "",
      "FromNumber": ""
    }
  }
}
